# Version control
.git
.gitignore
.gitattributes

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.py[cod]
*$py.class

# Build artefacts
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Test artefacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# Type checker / linter caches
.mypy_cache/
.ruff_cache/
.dmypy.json

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Data files — never in the image
data/
*.parquet
*.csv
*.json.gz
*.avro

# Terraform — not needed at runtime
infra/

# Docs
docs/
*.md
!README.md

# Secrets / env files
.env
.env.*
secrets/

# Docker files (avoid recursive COPY confusion)
Dockerfile*
docker-compose*.yml
.dockerignore

# CI
.github/

# macOS
.DS_Store
